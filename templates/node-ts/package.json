{
  "name": "backend-app",
  "version": "1.0.0",
  "description": "Node.js TypeScript backend template",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky install"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "helmet": "^7.0.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "cookie-parser": "^1.4.6"
  },
  "devDependencies": {
    "typescript": "^5.3.2",
    "ts-node": "^10.9.2",
    "nodemon": "^3.0.1",
    "eslint": "^8.57.0",
    "@typescript-eslint/parser": "^6.12.1",
    "@typescript-eslint/eslint-plugin": "^6.12.1",
    "prettier": "^3.1.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "@types/node": "^20.10.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/cookie-parser": "^1.4.6"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18"
  }
}
